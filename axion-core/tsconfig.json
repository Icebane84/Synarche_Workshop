{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "lib": [
            "ES2022"
        ],
        "sourceMap": true,
        "outDir": "out",
        "rootDir": "src",
        "strict": true,
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@system/*": [
                "./src/cse/*"
            ],
            "@domain/*": [
                "./src/02_domain/*"
            ],
            "@nexus/*": [
                "./src/nexus/*"
            ],
            "@fabric/*": [
                "./src/03_fabric/*"
            ],
            "@atlas/*": [
                "./src/01_atlas/*"
            ],
            "@essence/*": [
                "./src/types/*"
            ],
            "@shield/*": [
                "./sentinel/*"
            ],
            "@pulse/*": [
                "./_logs/*"
            ],
            "@loom/*": [
                "./templates/*"
            ],
            "@archive/*": [
                "./archives/*"
            ],
            "@universe/*": [
                "./_universe/*"
            ]
        }
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}