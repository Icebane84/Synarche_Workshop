{
    "folders": [
        {
            "name": "🧠 THE MIND",
            "path": ".agent"
        },
        {
            "name": "📜 THE LAW",
            "path": "_governance"
        },
        {
            "name": "⚙️ THE ENGINE (AXION)",
            "path": "axion-core"
        },
        {
