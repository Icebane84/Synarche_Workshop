{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm: compile",
            "type": "shell",
            "command": "npm run compile",
            "options": {
                "cwd": "${workspaceFolder}/axion-core"
            },
            "problemMatcher": [
                "$tsc"
            ]
        },
        {
            "label": "SYNG: Sentinel Scan [Auto-Fix]",
            "detail": "Execute Sentinel's Sword to auto-fix architectural and linting dissonance.",
            "type": "shell",
            "command": "C:\\DevEnvironments\\master_env\\Scripts\\python.exe",
            "args": [
                "axion-core/lab/sentinel_sword.py"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "SYNG: Governance Scan [Sophia]",
