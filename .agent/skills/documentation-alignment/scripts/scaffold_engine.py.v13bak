"""| Key               | Value                          | Description       |
| :---------------- | :----------------------------- | :---------------- |
| **Artifact ID**   | `TOOL-SCAFFOLD-ENGINE-001`     | The Sovereign ID. |
| **Official Name** | `scaffold_engine.py`           | The Filename.     |
| **Version**       | **v15.0 [OMEGA]**              | The Standard.     |
| **Domain**        | `GVRN`                         | The Subject.      |
| **Status (State)**| `[CANONIZED]`                  | The Lifecycle.    |
| **Relations**     | `GOVERNED_BY: CORE-CODEX-001`  | The Network.      |
"""

import argparse
import os
from pathlib import Path
from datetime import date
from governance_utils import (
    UIP_V15_MD_TEMPLATE, 
    UIP_V15_PY_TEMPLATE, 
    get_artifact_id, 
    generate_omni_anchor
)

MD_SCAFFOLD = """\
## I. Purpose

> _(Describe what this artifact does and why it exists.)_

## II. Content

> _(Main body of the artifact goes here.)_
"""

PY_SCAFFOLD = """\
import argparse
import logging

def main():
    # TODO: Implement tool logic
    pass

if __name__ == "__main__":
    main()
"""

def forge_scaffold(name: str, output: str, domain: str = "GVRN"):
    """Forge a new OMEGA v15.0 artifact."""
    out_path = Path(output).resolve()
    filename = out_path.name
    artifact_id = get_artifact_id(filename, domain)
    status = "[DRAFT]"
    today = date.today().isoformat()
    
    if filename.endswith(".py"):
        header = UIP_V15_PY_TEMPLATE.format(
            artifact_id=artifact_id, filename=filename, domain=domain, status=status, date=today
        )
        content = header + "\n" + PY_SCAFFOLD
    else:
        header = UIP_V15_MD_TEMPLATE.format(
            artifact_id=artifact_id, filename=filename, domain=domain, status=status, date=today
        )
        anchor = generate_omni_anchor(artifact_id, domain, status)
        content = f"{header}\n\n###### **[ARTIFACT START]**\n\n# {name}\n\n{MD_SCAFFOLD}\n\n###### **[ARTIFACT END]**\n\n---\n\n{anchor}"

    out_path.parent.mkdir(parents=True, exist_ok=True)
    out_path.write_text(content, encoding="utf-8")
    
    print(f"\n[OK] SCAFFOLD FORGED: {out_path}")
    print(f"     ID: {artifact_id}")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Scaffold Engine - OMEGA v15.0")
    parser.add_argument("name", help="Human-readable name")
    parser.add_argument("output", help="Output path (.md or .py)")
    parser.add_argument("--domain", default="GVRN", help="Domain label")
    args = parser.parse_args()
    forge_scaffold(args.name, args.output, args.domain)
